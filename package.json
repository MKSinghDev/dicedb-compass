{
    "name": "dicedb-insight",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "react-router build",
        "predev": "node -e \"if (parseInt(process.versions.node.split('.')[0]) < 22) throw new Error('Node.js version 22 or higher is required')\"",
        "dev": "react-router dev",
        "start": "react-router-serve ./build/server/index.js",
        "check-types": "tsc --pretty --noEmit",
        "check-format": "prettier --check .",
        "check-lint": "eslint . --ext ts --ext tsx --ext js --ext jsx",
        "format": "prettier --write .",
        "format:repo": "npm run format && npm run lint -- --fix",
        "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
        "lint:fix": "eslint . --ext ts --ext tsx --ext js --ext jsx --fix",
        "prepare": "node .husky/install.mjs",
        "typecheck": "react-router typegen && tsc"
    },
    "dependencies": {
        "@react-router/node": "^7.4.0",
        "@react-router/serve": "^7.4.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "isbot": "^5.1.25",
        "lucide-react": "^0.484.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-router": "^7.4.0",
        "remix-themes": "^2.0.4",
        "tailwind-merge": "^3.0.2",
        "tailwindcss-animate": "^1.0.7"
    },
    "devDependencies": {
        "@commitlint/cli": "^19.8.0",
        "@commitlint/config-conventional": "^19.8.0",
        "@react-router/dev": "^7.4.0",
        "@react-router/remix-routes-option-adapter": "^7.4.0",
        "@tailwindcss/vite": "^4.0.17",
        "@types/eslint": "^9.6.1",
        "@types/node": "^22",
        "@types/react": "^19.0.12",
        "@types/react-dom": "^19.0.4",
        "@typescript-eslint/eslint-plugin": "^8.28.0",
        "@typescript-eslint/parser": "^8.28.0",
        "eslint": "^9.23.0",
        "eslint-config-prettier": "^10.1.1",
        "eslint-config-standard-with-typescript": "^43.0.1",
        "eslint-import-resolver-typescript": "^4.2.5",
        "eslint-plugin-import": "^2.31.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-markdown": "^5.1.0",
        "eslint-plugin-n": "^17.17.0",
        "eslint-plugin-prettier": "^5.2.5",
        "eslint-plugin-promise": "^7.2.1",
        "eslint-plugin-react": "^7.37.4",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "eslint-plugin-unused-imports": "^4.1.4",
        "globals": "^16.0.0",
        "husky": "^9.1.7",
        "lint-staged": "^15.5.0",
        "match-sorter": "^8.0.0",
        "prettier": "^3.5.3",
        "prettier-plugin-tailwindcss": "^0.6.11",
        "react-router-devtools": "^1.1.7",
        "remix-flat-routes": "^0.8.5",
        "tailwindcss": "^4.0.17",
        "typescript": "^5.8.2",
        "vite": "^5.4.11",
        "vite-tsconfig-paths": "^5.1.4"
    },
    "engines": {
        "node": ">=22.0.0"
    }
}
